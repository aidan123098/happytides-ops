generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-arm64-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum RoleName {
  OWNER
  OPERATIONS_ADMIN
  SALES
  WAREHOUSE
  FINANCE
  ADMIN
  STAFF
  VIEWER
  WHOLESALE_PORTAL
}

enum UserStatus {
  ACTIVE
  INVITED
  SUSPENDED
  ARCHIVED
}

enum CustomerSource {
  WALK_IN
  REFERRAL
  EVENT
  INSTAGRAM
  WEBSITE
  OTHER
}

enum CustomerStatus {
  NEW
  RETURNING
  VIP
  INACTIVE
}

enum InventoryStatus {
  EXPECTED
  RECEIVED
  QUARANTINED
  PENDING_QA
  QA_RELEASED
  AVAILABLE
  ON_HOLD
  EXPIRED
  RECALLED
  DESTROYED
  ARCHIVED
  RESERVED
  SOLD
  DAMAGED
}

enum InventoryMovementType {
  INITIAL_RECEIPT
  PURCHASE_RECEIPT
  MANUAL_ADJUSTMENT
  CYCLE_COUNT
  ORDER_RESERVATION
  ORDER_ALLOCATION
  ORDER_FULFILLMENT
  ORDER_CANCELLATION
  RETURN_RECEIPT
  DAMAGE
  SAMPLE
  TRANSFER_OUT
  TRANSFER_IN
  QUARANTINE
  RELEASE
  RECALL
  DESTRUCTION
  RECEIVED
  RESERVED
  SOLD
  ADJUSTED
  RETURNED
  EXPIRED
  QUARANTINED
  DAMAGED
}

enum PaymentMethod {
  SQUARE_CARD
  CASH
  ACH
  WIRE
  ZELLE
  VENMO
  CHECK
  ACCOUNT_CREDIT
  OTHER
}

enum PaymentStatus {
  UNPAID
  PENDING
  PARTIALLY_PAID
  PAID
  OVERPAID
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
  CANCELED
  VOIDED
}

enum FulfillmentStatus {
  UNFULFILLED
  PARTIALLY_ALLOCATED
  ALLOCATED
  PICKING
  PACKED
  FULFILLED
  PARTIALLY_FULFILLED
  CANCELED
}

enum OrderStatus {
  DRAFT
  QUOTE_SENT
  AWAITING_APPROVAL
  AWAITING_PAYMENT
  PARTIALLY_PAID
  PAID
  ALLOCATED
  PICKING
  PACKING
  READY_TO_SHIP
  SHIPPED
  DELIVERED
  COMPLETED
  ON_HOLD
  CANCELED
  PARTIALLY_REFUNDED
  REFUNDED
  RETURNED
}

enum AccountType {
  RETAIL_CUSTOMER
  WHOLESALE_ACCOUNT
  DISTRIBUTOR
  SUPPLIER
  INTERNAL
}

enum AccountStatus {
  LEAD
  PENDING_APPROVAL
  ACTIVE
  ON_HOLD
  SUSPENDED
  ARCHIVED
}

enum DocumentType {
  COA
  SDS
  INVOICE
  PACKING_SLIP
  PURCHASE_ORDER
  CONTRACT
  RESALE_CERTIFICATE
  QUALITY_RECORD
  OTHER
}

enum DocumentVisibility {
  INTERNAL_ONLY
  WHOLESALE_PORTAL
  PUBLIC_QR
}

enum DocumentStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  PUBLISHED
  SUPERSEDED
  REVOKED
  ARCHIVED
}

enum AuditEntityType {
  USER
  ACCOUNT
  CONTACT
  CUSTOMER
  PRODUCT
  INVENTORY
  ORDER
  PAYMENT
  REFUND
  DOCUMENT
  SQUARE
  SETTINGS
  AFFILIATE
}

model User {
  id                  String               @id @default(cuid())
  name                String
  email               String               @unique
  passwordHash        String?
  firstName           String?              @map("first_name")
  lastName            String?              @map("last_name")
  displayName         String?              @map("display_name")
  phone               String?
  avatarUrl           String?              @map("avatar_url")
  status              UserStatus           @default(ACTIVE)
  active              Boolean              @default(true)
  lastLoginAt         DateTime?            @map("last_login_at")
  lastActiveAt        DateTime?            @map("last_active_at")
  roles               UserRole[]
  sessions            Session[]
  passwordResetTokens PasswordResetToken[]
  mfaMethods          MfaMethod[]
  loginAttempts       LoginAttempt[]
  activities          UserActivity[]
  assignedAccounts    Account[]            @relation("AssignedSalesRep")
  orders              Order[]              @relation("StaffOrders")
  inventoryMovements  InventoryMovement[]
  auditLogs           AuditLog[]
  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @updatedAt @map("updated_at")
  archivedAt          DateTime?            @map("archived_at")

  @@map("users")
}

model Session {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  ipAddress String?   @map("ip_address")
  userAgent String?   @map("user_agent")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@index([userId, expiresAt])
  @@map("sessions")
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@index([userId, expiresAt])
  @@map("password_reset_tokens")
}

model MfaMethod {
  id         String    @id @default(cuid())
  userId     String    @map("user_id")
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type       String
  secretHash String?   @map("secret_hash")
  enabled    Boolean   @default(false)
  verifiedAt DateTime? @map("verified_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  archivedAt DateTime? @map("archived_at")

  @@index([userId, enabled])
  @@map("mfa_methods")
}

model LoginAttempt {
  id        String   @id @default(cuid())
  userId    String?  @map("user_id")
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  email     String
  success   Boolean
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  reason    String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([email, createdAt])
  @@index([userId, createdAt])
  @@map("login_attempts")
}

model UserActivity {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action     String
  entityType String?  @map("entity_type")
  entityId   String?  @map("entity_id")
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([userId, createdAt])
  @@map("user_activities")
}

model Role {
  id          String     @id @default(cuid())
  name        RoleName   @unique
  description String
  users       UserRole[]
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  @@map("roles")
}

model UserRole {
  userId    String   @map("user_id")
  roleId    String   @map("role_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@id([userId, roleId])
  @@map("user_roles")
}

model Customer {
  id                     String                  @id @default(cuid())
  firstName              String                  @map("first_name")
  lastName               String                  @map("last_name")
  email                  String?                 @unique
  phone                  String?
  smsConsent             Boolean                 @default(false) @map("sms_consent")
  emailConsent           Boolean                 @default(false) @map("email_consent")
  firstPurchaseAt        DateTime?               @map("first_purchase_at")
  lastPurchaseAt         DateTime?               @map("last_purchase_at")
  totalSpendCents        Int                     @default(0) @map("total_spend_cents")
  orderCount             Int                     @default(0) @map("order_count")
  averageOrderValueCents Int                     @default(0) @map("average_order_value_cents")
  favoriteProductId      String?                 @map("favorite_product_id")
  favoriteProduct        Product?                @relation(fields: [favoriteProductId], references: [id])
  notes                  String?
  source                 CustomerSource          @default(WALK_IN)
  status                 CustomerStatus          @default(NEW)
  squareCustomerId       String?                 @unique @map("square_customer_id")
  orders                 Order[]
  accountId              String?                 @map("account_id")
  account                Account?                @relation(fields: [accountId], references: [id])
  tags                   CustomerTagAssignment[]
  createdAt              DateTime                @default(now()) @map("created_at")
  updatedAt              DateTime                @updatedAt @map("updated_at")
  archivedAt             DateTime?               @map("archived_at")

  @@index([lastName, firstName])
  @@map("customers")
}

model Account {
  id                       String            @id @default(cuid())
  accountNumber            String            @unique @map("account_number")
  name                     String
  type                     AccountType       @default(RETAIL_CUSTOMER)
  status                   AccountStatus     @default(ACTIVE)
  primaryContactId         String?           @unique @map("primary_contact_id")
  primaryContact           Contact?          @relation("PrimaryContact", fields: [primaryContactId], references: [id])
  assignedSalesRepId       String?           @map("assigned_sales_rep_id")
  assignedSalesRep         User?             @relation("AssignedSalesRep", fields: [assignedSalesRepId], references: [id])
  priceListId              String?           @map("price_list_id")
  priceList                PriceList?        @relation(fields: [priceListId], references: [id])
  paymentTerms             String?           @map("payment_terms")
  creditLimitCents         Int               @default(0) @map("credit_limit_cents")
  currentBalanceCents      Int               @default(0) @map("current_balance_cents")
  lifetimeRevenueCents     Int               @default(0) @map("lifetime_revenue_cents")
  lifetimeGrossProfitCents Int               @default(0) @map("lifetime_gross_profit_cents")
  orderCount               Int               @default(0) @map("order_count")
  firstOrderAt             DateTime?         @map("first_order_at")
  lastOrderAt              DateTime?         @map("last_order_at")
  notes                    String?
  contacts                 AccountContact[]
  addresses                Address[]
  customers                Customer[]
  orders                   Order[]
  documents                AccountDocument[]
  activities               AccountActivity[]
  createdAt                DateTime          @default(now()) @map("created_at")
  updatedAt                DateTime          @updatedAt @map("updated_at")
  archivedAt               DateTime?         @map("archived_at")

  @@index([name])
  @@index([type, status])
  @@map("accounts")
}

model Contact {
  id                      String           @id @default(cuid())
  firstName               String           @map("first_name")
  lastName                String           @map("last_name")
  email                   String?          @unique
  phone                   String?
  title                   String?
  communicationPreference String?          @map("communication_preference")
  smsConsent              Boolean          @default(false) @map("sms_consent")
  emailConsent            Boolean          @default(false) @map("email_consent")
  notes                   String?
  primaryFor              Account?         @relation("PrimaryContact")
  accounts                AccountContact[]
  createdAt               DateTime         @default(now()) @map("created_at")
  updatedAt               DateTime         @updatedAt @map("updated_at")
  archivedAt              DateTime?        @map("archived_at")

  @@index([lastName, firstName])
  @@map("contacts")
}

model AccountContact {
  accountId String   @map("account_id")
  contactId String   @map("contact_id")
  account   Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  role      String?
  primary   Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@id([accountId, contactId])
  @@map("account_contacts")
}

model Address {
  id         String    @id @default(cuid())
  accountId  String    @map("account_id")
  account    Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  type       String
  line1      String
  line2      String?
  city       String
  region     String?
  postalCode String?   @map("postal_code")
  country    String    @default("US")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  archivedAt DateTime? @map("archived_at")

  @@index([accountId, type])
  @@map("addresses")
}

model PriceList {
  id          String          @id @default(cuid())
  name        String          @unique
  description String?
  active      Boolean         @default(true)
  accounts    Account[]
  items       PriceListItem[]
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")
  archivedAt  DateTime?       @map("archived_at")

  @@map("price_lists")
}

model PriceListItem {
  id             String    @id @default(cuid())
  priceListId    String    @map("price_list_id")
  priceList      PriceList @relation(fields: [priceListId], references: [id], onDelete: Cascade)
  productId      String    @map("product_id")
  product        Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  unitPriceCents Int       @map("unit_price_cents")
  minQuantity    Int       @default(1) @map("min_quantity")
  startsAt       DateTime? @map("starts_at")
  endsAt         DateTime? @map("ends_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@unique([priceListId, productId, minQuantity])
  @@map("price_list_items")
}

model AccountDocument {
  id         String   @id @default(cuid())
  accountId  String   @map("account_id")
  documentId String   @map("document_id")
  account    Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@unique([accountId, documentId])
  @@map("account_documents")
}

model AccountActivity {
  id        String   @id @default(cuid())
  accountId String   @map("account_id")
  account   Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  action    String
  note      String?
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([accountId, createdAt])
  @@map("account_activities")
}

model CustomerTag {
  id        String                  @id @default(cuid())
  name      String                  @unique
  color     String                  @default("#1f6feb")
  customers CustomerTagAssignment[]
  createdAt DateTime                @default(now()) @map("created_at")
  updatedAt DateTime                @updatedAt @map("updated_at")

  @@map("customer_tags")
}

model CustomerTagAssignment {
  customerId String      @map("customer_id")
  tagId      String      @map("tag_id")
  customer   Customer    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  tag        CustomerTag @relation(fields: [tagId], references: [id], onDelete: Cascade)
  createdAt  DateTime    @default(now()) @map("created_at")
  updatedAt  DateTime    @updatedAt @map("updated_at")

  @@id([customerId, tagId])
  @@map("customer_tag_assignments")
}

model ProductCategory {
  id          String    @id @default(cuid())
  name        String    @unique
  description String?
  products    Product[]
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@map("product_categories")
}

model Product {
  id                       String                       @id @default(cuid())
  name                     String
  sku                      String                       @unique
  categoryId               String                       @map("category_id")
  category                 ProductCategory              @relation(fields: [categoryId], references: [id])
  peptideType              String                       @map("peptide_type")
  strengthLabel            String                       @map("strength_label")
  priceCents               Int                          @map("price_cents")
  costOfGoodsCents         Int                          @map("cost_of_goods_cents")
  active                   Boolean                      @default(true)
  colorAccent              String                       @default("#1f6feb") @map("color_accent")
  description              String?
  coaUrl                   String?                      @map("coa_url")
  researchUseDisclaimer    String                       @map("research_use_disclaimer")
  imageUrl                 String?                      @map("image_url")
  inventoryTrackingEnabled Boolean                      @default(true) @map("inventory_tracking_enabled")
  slug                     String?                      @unique
  status                   String                       @default("ACTIVE")
  internalSku              String?                      @map("internal_sku")
  internalNotes            String?                      @map("internal_notes")
  unitOfMeasure            String?                      @map("unit_of_measure")
  wholesalePriceCents      Int                          @default(0) @map("wholesale_price_cents")
  minimumOrderQuantity     Int                          @default(1) @map("minimum_order_quantity")
  reorderPoint             Int                          @default(0) @map("reorder_point")
  reorderQuantity          Int                          @default(0) @map("reorder_quantity")
  shelfLifeDays            Int?                         @map("shelf_life_days")
  barcode                  String?
  priceListItems           PriceListItem[]
  documents                Document[]
  inventoryBatches         InventoryBatch[]
  orderItems               OrderItem[]
  favoriteForCustomers     Customer[]
  performanceSnapshots     ProductPerformanceSnapshot[]
  createdAt                DateTime                     @default(now()) @map("created_at")
  updatedAt                DateTime                     @updatedAt @map("updated_at")
  archivedAt               DateTime?                    @map("archived_at")

  @@index([name])
  @@map("products")
}

model InventoryBatch {
  id                  String              @id @default(cuid())
  productId           String              @map("product_id")
  product             Product             @relation(fields: [productId], references: [id])
  quantityOnHand      Int                 @default(0) @map("quantity_on_hand")
  quantityReserved    Int                 @default(0) @map("quantity_reserved")
  quantitySold        Int                 @default(0) @map("quantity_sold")
  reorderThreshold    Int                 @default(10) @map("reorder_threshold")
  batchNumber         String              @map("batch_number")
  lotNumber           String              @map("lot_number")
  expirationDate      DateTime            @map("expiration_date")
  supplier            String
  costPerVialCents    Int                 @map("cost_per_vial_cents")
  storageRequirements String              @map("storage_requirements")
  coaDocumentUrl      String?             @map("coa_document_url")
  status              InventoryStatus     @default(AVAILABLE)
  releasedAt          DateTime?           @map("released_at")
  releasedById        String?             @map("released_by_id")
  quarantineReason    String?             @map("quarantine_reason")
  holdReason          String?             @map("hold_reason")
  recallStatus        String?             @map("recall_status")
  movements           InventoryMovement[]
  orderItems          OrderItem[]
  lotDocuments        LotDocument[]
  createdAt           DateTime            @default(now()) @map("created_at")
  updatedAt           DateTime            @updatedAt @map("updated_at")
  archivedAt          DateTime?           @map("archived_at")

  @@unique([productId, batchNumber, lotNumber])
  @@index([batchNumber])
  @@index([lotNumber])
  @@map("inventory_batches")
}

model InventoryMovement {
  id             String                @id @default(cuid())
  batchId        String                @map("batch_id")
  batch          InventoryBatch        @relation(fields: [batchId], references: [id])
  type           InventoryMovementType
  quantityDelta  Int                   @map("quantity_delta")
  quantityBefore Int?                  @map("quantity_before")
  quantityAfter  Int?                  @map("quantity_after")
  referenceType  String?               @map("reference_type")
  referenceId    String?               @map("reference_id")
  reason         String
  orderItemId    String?               @map("order_item_id")
  orderItem      OrderItem?            @relation(fields: [orderItemId], references: [id])
  adjustedById   String                @map("adjusted_by_id")
  adjustedBy     User                  @relation(fields: [adjustedById], references: [id])
  createdAt      DateTime              @default(now()) @map("created_at")
  updatedAt      DateTime              @updatedAt @map("updated_at")

  @@index([createdAt])
  @@map("inventory_movements")
}

model Document {
  id           String             @id @default(cuid())
  type         DocumentType
  status       DocumentStatus     @default(DRAFT)
  visibility   DocumentVisibility @default(INTERNAL_ONLY)
  title        String
  fileName     String?            @map("file_name")
  mimeType     String?            @map("mime_type")
  fileSize     Int?               @map("file_size")
  storageKey   String?            @map("storage_key")
  checksum     String?
  version      Int                @default(1)
  productId    String?            @map("product_id")
  product      Product?           @relation(fields: [productId], references: [id])
  uploadedById String?            @map("uploaded_by_id")
  approvedById String?            @map("approved_by_id")
  approvedAt   DateTime?          @map("approved_at")
  expiresAt    DateTime?          @map("expires_at")
  notes        String?
  accountLinks AccountDocument[]
  lotLinks     LotDocument[]
  createdAt    DateTime           @default(now()) @map("created_at")
  updatedAt    DateTime           @updatedAt @map("updated_at")
  archivedAt   DateTime?          @map("archived_at")

  @@index([type, status])
  @@index([productId])
  @@map("documents")
}

model LotDocument {
  id         String         @id @default(cuid())
  batchId    String         @map("batch_id")
  batch      InventoryBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  documentId String         @map("document_id")
  document   Document       @relation(fields: [documentId], references: [id], onDelete: Cascade)
  createdAt  DateTime       @default(now()) @map("created_at")
  updatedAt  DateTime       @updatedAt @map("updated_at")

  @@unique([batchId, documentId])
  @@map("lot_documents")
}

model StaffLocation {
  id        String   @id @default(cuid())
  name      String
  type      String   @default("retail")
  active    Boolean  @default(true)
  orders    Order[]
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("staff_locations")
}

model Order {
  id                String            @id @default(cuid())
  orderNumber       String            @unique @map("order_number")
  customerId        String            @map("customer_id")
  customer          Customer          @relation(fields: [customerId], references: [id])
  staffMemberId     String            @map("staff_member_id")
  staffMember       User              @relation("StaffOrders", fields: [staffMemberId], references: [id])
  locationId        String?           @map("location_id")
  location          StaffLocation?    @relation(fields: [locationId], references: [id])
  subtotalCents     Int               @map("subtotal_cents")
  discountCents     Int               @default(0) @map("discount_cents")
  taxCents          Int               @default(0) @map("tax_cents")
  totalCents        Int               @map("total_cents")
  paymentStatus     PaymentStatus     @default(PENDING) @map("payment_status")
  fulfillmentStatus FulfillmentStatus @default(UNFULFILLED) @map("fulfillment_status")
  status            OrderStatus       @default(PAID)
  accountId         String?           @map("account_id")
  account           Account?          @relation(fields: [accountId], references: [id])
  orderSource       String?           @map("order_source")
  affiliateId       String?           @map("affiliate_id")
  affiliate         Affiliate?        @relation(fields: [affiliateId], references: [id])
  squareOrderId     String?           @unique @map("square_order_id")
  notes             String?
  canceledAt        DateTime?         @map("canceled_at")
  refundedAt        DateTime?         @map("refunded_at")
  items             OrderItem[]
  payments          Payment[]
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")
  archivedAt        DateTime?         @map("archived_at")

  @@index([createdAt])
  @@map("orders")
}

model OrderItem {
  id               String              @id @default(cuid())
  orderId          String              @map("order_id")
  order            Order               @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId        String              @map("product_id")
  product          Product             @relation(fields: [productId], references: [id])
  inventoryBatchId String?             @map("inventory_batch_id")
  inventoryBatch   InventoryBatch?     @relation(fields: [inventoryBatchId], references: [id])
  quantity         Int
  unitPriceCents   Int                 @map("unit_price_cents")
  discountCents    Int                 @default(0) @map("discount_cents")
  taxCents         Int                 @default(0) @map("tax_cents")
  totalCents       Int                 @map("total_cents")
  movements        InventoryMovement[]
  createdAt        DateTime            @default(now()) @map("created_at")
  updatedAt        DateTime            @updatedAt @map("updated_at")

  @@map("order_items")
}

model Payment {
  id              String        @id @default(cuid())
  orderId         String        @map("order_id")
  order           Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  method          PaymentMethod
  status          PaymentStatus @default(PENDING)
  amountCents     Int           @map("amount_cents")
  squarePaymentId String?       @unique @map("square_payment_id")
  paidAt          DateTime?     @map("paid_at")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  archivedAt      DateTime?     @map("archived_at")

  @@map("payments")
}

model SquareEvent {
  id              String    @id @default(cuid())
  squareEventId   String    @unique @map("square_event_id")
  eventType       String    @map("event_type")
  payload         Json
  processedAt     DateTime? @map("processed_at")
  processingError String?   @map("processing_error")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@map("square_events")
}

model SquareSyncRun {
  id                  String    @id @default(cuid())
  status              String
  startedAt           DateTime  @default(now()) @map("started_at")
  finishedAt          DateTime? @map("finished_at")
  error               String?
  catalogItemsChecked Int       @default(0) @map("catalog_items_checked")
  paymentsChecked     Int       @default(0) @map("payments_checked")
  ordersChecked       Int       @default(0) @map("orders_checked")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  @@index([status, startedAt])
  @@map("square_sync_runs")
}

model Affiliate {
  id                    String    @id @default(cuid())
  name                  String?
  code                  String?   @unique
  status                String    @default("pending")
  revenueGeneratedCents Int       @default(0) @map("revenue_generated_cents")
  payoutRateBps         Int       @default(0) @map("payout_rate_bps")
  totalPayoutCents      Int       @default(0) @map("total_payout_cents")
  payoutDueCents        Int       @default(0) @map("payout_due_cents")
  referredCustomers     Int       @default(0) @map("referred_customers")
  referredOrders        Int       @default(0) @map("referred_orders")
  lastPayoutAt          DateTime? @map("last_payout_at")
  notes                 String?
  orders                Order[]
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")
  archivedAt            DateTime? @map("archived_at")

  @@index([status])
  @@map("affiliates")
}

model AuditLog {
  id         String          @id @default(cuid())
  actorId    String?         @map("actor_id")
  actor      User?           @relation(fields: [actorId], references: [id])
  entityType AuditEntityType @map("entity_type")
  entityId   String          @map("entity_id")
  action     String
  before     Json?
  after      Json?
  metadata   Json?
  ipAddress  String?         @map("ip_address")
  userAgent  String?         @map("user_agent")
  createdAt  DateTime        @default(now()) @map("created_at")
  updatedAt  DateTime        @updatedAt @map("updated_at")

  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

model ProductPerformanceSnapshot {
  id               String   @id @default(cuid())
  productId        String   @map("product_id")
  product          Product  @relation(fields: [productId], references: [id])
  snapshotDate     DateTime @map("snapshot_date")
  unitsSold        Int      @default(0) @map("units_sold")
  revenueCents     Int      @default(0) @map("revenue_cents")
  grossMarginCents Int      @default(0) @map("gross_margin_cents")
  sellThroughRate  Float    @default(0) @map("sell_through_rate")
  daysRemaining    Int?     @map("days_remaining")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@unique([productId, snapshotDate])
  @@map("product_performance_snapshots")
}
